# GEMINI_API_KEY: Server-only Gemini API key, used by the /api/gemini-token
# serverless function to mint short-lived ephemeral tokens for the browser.
# IMPORTANT: do NOT prefix with VITE_ — that would bundle it into the client
# and expose it to anyone visiting the site.
# In production, set this in the Vercel project Environment Variables UI.
# For local dev with `vercel dev`, run `vercel env pull .env.local` instead.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
